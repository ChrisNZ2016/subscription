# Client (Vite — exposed to browser)
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
VITE_SHOPIFY_API_VERSION=2025-01
VITE_SAMPLE_PRODUCT_HANDLE=sample-2kg
VITE_SUBSCRIPTION_PRODUCT_HANDLE=kibble-pack
VITE_ADDON_HANDLES=poop-bags,dog-treats
VITE_MIXPANEL_TOKEN=your-mixpanel-token
# Meta pixel — same ID as the Facebook & Instagram Shopify app
VITE_META_PIXEL_ID=194052245

# Server (Vercel only — never VITE_ prefix)
MIXPANEL_TOKEN=your-mixpanel-token
SHOPIFY_WEBHOOK_SECRET=your-webhook-signing-secret
META_PIXEL_ID=194052245
META_CAPI_ACCESS_TOKEN=your-meta-capi-access-token
